# Copier vers backend/.env sur EC2 (ne jamais committer backend/.env.ec2)
# cp backend/.env.ec2.example backend/.env

APP_ENV=production
APP_DEBUG=false
FRONTEND_URL=https://votre-frontend.vercel.app

SECRET_KEY=remplacer-par-une-chaine-aleatoire-64-caracteres

FIREBASE_PROJECT_ID=techmentor-ai
FIREBASE_CREDENTIALS_PATH=/app/firebase-service-account.json

DATABASE_URL=postgresql+asyncpg://user:pass@host/db
SYNC_DATABASE_URL=postgresql+psycopg://user:pass@host/db?sslmode=require

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

QDRANT_URL=https://VOTRE-CLUSTER.cloud.qdrant.io:6333
QDRANT_API_KEY=votre-cle-qdrant
QDRANT_COLLECTION=kb_chunks
SKIP_RAG_INGEST=0

MISTRAL_API_KEY=votre-cle-llm
MISTRAL_BASE_URL=https://api.groq.com/openai/v1
MISTRAL_DEFAULT_MODEL=llama-3.3-70b-versatile

GEMINI_API_KEY=votre-cle-gemini
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

BACKEND_CORS_ORIGINS=["https://votre-frontend.vercel.app","http://localhost:3000"]
