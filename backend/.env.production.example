# =====================================================================
# TechMentor AI - Backend PRODUCTION (EC2 / VPS)
# Copier vers backend/.env sur le serveur et remplir les valeurs.
# =====================================================================

# ---- App ----
APP_NAME=TechMentor AI
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
# URL du frontend deploye (CORS)
FRONTEND_URL=https://votre-frontend.example.com

# ---- Firebase Auth ----
FIREBASE_PROJECT_ID=techmentor-ai
FIREBASE_CREDENTIALS_PATH=/app/firebase-service-account.json
FIREBASE_CREDENTIALS_JSON=

# ---- Security ----
SECRET_KEY=remplacer-par-une-chaine-aleatoire-de-64-caracteres-minimum

# ---- Database (noms de services Docker) ----
POSTGRES_USER=techmentor
POSTGRES_PASSWORD=choisir-un-mot-de-passe-fort
POSTGRES_DB=techmentor
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://techmentor:choisir-un-mot-de-passe-fort@postgres:5432/techmentor
SYNC_DATABASE_URL=postgresql+psycopg://techmentor:choisir-un-mot-de-passe-fort@postgres:5432/techmentor

# ---- Redis / Celery ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- Qdrant (RAG) ----
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=kb_chunks
EMBEDDING_DIMENSION=1536
SKIP_RAG_INGEST=0

# ---- LLM ----
MISTRAL_API_KEY=votre-cle-llm
MISTRAL_BASE_URL=https://api.groq.com/openai/v1
MISTRAL_DEFAULT_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT_SECONDS=60

# ---- Gemini (embeddings) ----
GEMINI_API_KEY=votre-cle-gemini
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_TIMEOUT_SECONDS=60

# ---- Fichiers ----
UPLOAD_DIR=./uploads
MAX_CV_SIZE_MB=5
CV_STORAGE_BACKEND=local
CV_USE_CELERY=true
CV_PROCESSING_STALE_SECONDS=20
GITHUB_PROCESSING_STALE_SECONDS=20
# GITHUB_API_TOKEN=

# ---- CORS (URL du frontend) ----
BACKEND_CORS_ORIGINS=["https://votre-frontend.example.com"]

# ---- Port expose sur l'hote EC2 (optionnel, defaut 8000) ----
# BACKEND_PORT=8000
