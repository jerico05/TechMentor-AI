# =====================================================================
# TechMentor AI - Backend Environment Configuration (example)
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
# =====================================================================

# ---- App ----
APP_NAME=TechMentor AI
APP_ENV=local                      # local | staging | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
FRONTEND_URL=http://localhost:3000

# ---- Firebase Auth (Admin SDK - server-side only) ----
FIREBASE_PROJECT_ID=techmentor-ai
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
# Or inline JSON (single line) - useful in CI; leave empty when using path above.
FIREBASE_CREDENTIALS_JSON=

# ---- Security (app secrets, not auth tokens) ----
SECRET_KEY=change-me-please-use-a-64-char-random-string

# ---- Database (PostgreSQL) ----
POSTGRES_USER=techmentor
POSTGRES_PASSWORD=techmentor
POSTGRES_DB=techmentor
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Built from above by default; override only if needed.
DATABASE_URL=postgresql+asyncpg://techmentor:techmentor@postgres:5432/techmentor
SYNC_DATABASE_URL=postgresql+psycopg://techmentor:techmentor@postgres:5432/techmentor

# ---- Redis ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- Qdrant (Vector DB) ----
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=kb_chunks
EMBEDDING_DIMENSION=1536

# ---- LLM (OpenAI-compatible - Groq, Mistral, OpenAI, etc.) ----
# Groq (recommandé dev) : https://console.groq.com/keys
#   MISTRAL_BASE_URL=https://api.groq.com/openai/v1
#   MISTRAL_DEFAULT_MODEL=llama-3.3-70b-versatile
# Mistral : https://console.mistral.ai/
#   MISTRAL_BASE_URL=https://api.mistral.ai/v1
#   MISTRAL_DEFAULT_MODEL=ministral-3b-latest
MISTRAL_API_KEY=your-llm-api-key
MISTRAL_BASE_URL=https://api.groq.com/openai/v1
MISTRAL_DEFAULT_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT_SECONDS=60

# ---- Gemini (embeddings, OpenAI-compatible) ----
# Docs: https://ai.google.dev/gemini-api/docs/openai
GEMINI_API_KEY=your-gemini-api-key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_TIMEOUT_SECONDS=60

# ---- OAuth (legacy - handled by Firebase on the client) ----
# GOOGLE_CLIENT_ID=
# GITHUB_CLIENT_ID=

# ---- File storage ----
UPLOAD_DIR=./uploads
MAX_CV_SIZE_MB=5
# local | cloudinary (test / prod sans disque local)
CV_STORAGE_BACKEND=local
# Traitement inline par défaut (pas besoin du worker Celery). Mettre true avec docker compose --profile worker.
CV_USE_CELERY=false
CV_PROCESSING_STALE_SECONDS=20
GITHUB_PROCESSING_STALE_SECONDS=20
# Optionnel : token GitHub pour éviter les limites API (Settings → Developer settings → PAT, scope public_repo)
# GITHUB_API_TOKEN=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_CV_FOLDER=techmentor/cvs

# ---- CORS ----
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
