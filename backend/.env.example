# =====================================================================
# TechMentor AI — Backend Environment Configuration (example)
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
# =====================================================================

# ---- App ----
APP_NAME=TechMentor AI
APP_ENV=local                      # local | staging | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
FRONTEND_URL=http://localhost:3000

# ---- Firebase Auth (Admin SDK — server-side only) ----
FIREBASE_PROJECT_ID=techmentor-ai
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
# Or inline JSON (single line) — useful in CI; leave empty when using path above.
FIREBASE_CREDENTIALS_JSON=

# ---- Security (app secrets, not auth tokens) ----
SECRET_KEY=change-me-please-use-a-64-char-random-string

# ---- Database (PostgreSQL) ----
POSTGRES_USER=techmentor
POSTGRES_PASSWORD=techmentor
POSTGRES_DB=techmentor
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Built from above by default; override only if needed.
DATABASE_URL=postgresql+asyncpg://techmentor:techmentor@postgres:5432/techmentor

# ---- Redis ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- Qdrant (Vector DB) ----
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=kb_chunks
EMBEDDING_DIMENSION=1536

# ---- RodiumAI (LLM gateway, OpenAI-compatible) ----
# Docs: https://www.rodiumai.io/  — base_url points to the OpenAI-compatible endpoint.
RODIUM_API_KEY=your-rodium-api-key
RODIUM_BASE_URL=https://api.rodiumai.io/v1
RODIUM_DEFAULT_MODEL=mistralai/mistral-small-latest
RODIUM_EMBEDDING_MODEL=text-embedding-3-small
RODIUM_TIMEOUT_SECONDS=60

# ---- OAuth (legacy — handled by Firebase on the client) ----
# GOOGLE_CLIENT_ID=
# GITHUB_CLIENT_ID=

# ---- File storage ----
UPLOAD_DIR=./uploads
MAX_CV_SIZE_MB=5

# ---- CORS ----
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
